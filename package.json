{
  "name": "whereareyou-api",
  "version": "0.1.0",
  "private": true,
  "description": "Reference resolver node for the whereareyou location handover protocol",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "start:prod": "node dist/index.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@whereareyou/protocol": "github:stu-greenshoots/whereareyou-protocol",
    "fastify": "^5.2.0",
    "ioredis": "^5.11.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
