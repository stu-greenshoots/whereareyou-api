# Resolver access mode: "open" or "apikey".
#   open   - anyone may resolve any code. Frictionless for demos and
#            materially insecure: claim-on-read is disabled because an
#            unauthenticated caller has no identity to bind a code to.
#   apikey - resolvers present a bearer key. The default for anything real.
RESOLVER_MODE=open

# Required when RESOLVER_MODE=apikey. Format: key:identity,key:identity
# API_KEYS=key-alpha:control-room-a,key-bravo:control-room-b

# Session store.
#
# Set   -> sessions live in Redis under a native TTL. Expiry is STRUCTURAL: the
#          record cannot outlive its TTL, there is no sweeper, and nothing has
#          to remember to delete anything.
# Unset -> sessions live in this process's heap and are swept periodically.
#          Expiry is POLICY ONLY. Fine for tests; not a claim to make to an
#          emergency service. The server warns loudly about this at startup.
#
# If this is set and Redis will not answer, the process refuses to start. That
# is deliberate: falling back to memory would keep the resolver serving while
# quietly dropping the guarantee it advertises.
REDIS_URL=redis://localhost:6379

PORT=8787
HOST=0.0.0.0

# Session lifetime bounds, in seconds.
DEFAULT_TTL_SECONDS=1800
MIN_TTL_SECONDS=60
MAX_TTL_SECONDS=14400

# Comma-separated origins, or * for any.
CORS_ORIGINS=*

LOG_LEVEL=info

# ---- Rate limiting and enumeration defence --------------------------------

# Off is legitimate for local development and a terrible idea anywhere else:
# without it the resolver can be walked through the code space.
RATE_LIMIT_ENABLED=true

# Trust X-Forwarded-For when deriving the client IP.
# Off by default, and that default matters: behind no proxy, anyone who can set
# the header mints a fresh rate-limit identity per request and the per-IP budget
# becomes decoration. Turn it ON behind a real proxy (Render, Fly, nginx), or
# every request appears to come from the proxy and shares one bucket.
TRUST_PROXY=false

# The resolve budget, and the asymmetry that is the whole point of it.
#
# A failed lookup costs 30x a successful one, because the miss rate is what
# separates an attacker from a dispatcher. At these defaults 600 hits a minute
# pass freely while 20 misses exhaust the same budget. The server refuses to
# start if MISS_COST does not exceed HIT_COST — the asymmetry is not optional.
RATE_RESOLVE_WINDOW_SECONDS=60
RATE_RESOLVE_BUDGET=600
RATE_RESOLVE_HIT_COST=1
RATE_RESOLVE_MISS_COST=30

# Minting is deliberately loose and skips the block check entirely. Throttling
# someone pressing the button because they are in trouble is a worse failure
# than absorbing some abuse.
RATE_MINT_WINDOW_SECONDS=60
RATE_MINT_BUDGET=120

# Consecutive misses before backoff engages, then 2s, 4s, 8s ... up to the cap.
# A successful lookup clears the streak, so a dispatcher who mistypes once does
# not accumulate a penalty.
RATE_MISS_STREAK_THRESHOLD=5
RATE_BACKOFF_BASE_SECONDS=2
RATE_BACKOFF_MAX_SECONDS=300
RATE_MISS_STREAK_MEMORY_SECONDS=900

# ---- Tests ----------------------------------------------------------------

# Redis used by the integration tests. They skip loudly if it is unreachable —
# a skipped structural-expiry suite means the central claim went unverified.
# TEST_REDIS_URL=redis://127.0.0.1:6379
